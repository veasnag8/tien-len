{
  "name": "@tien-len/backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "npx nest build",
    "start": "npx nest start",
    "start:dev": "npx nest start --watch",
    "start:prod": "node dist/main.js",
    "start:cloud": "npx prisma migrate deploy --schema=../Database/schema.prisma && node dist/main.js",
    "lint": "npx tsc -p tsconfig.json --noEmit",
    "test": "jest --passWithNoTests",
    "prisma:generate": "npx prisma generate --schema=../Database/schema.prisma",
    "prisma:migrate": "npx prisma migrate deploy --schema=../Database/schema.prisma",
    "prisma:migrate:dev": "npx prisma migrate dev --schema=../Database/schema.prisma",
    "prisma:seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/cli": "^11.0.2",
    "@nestjs/common": "^11.0.7",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.7",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.7",
    "@nestjs/platform-socket.io": "^11.0.7",
    "@nestjs/throttler": "^6.4.0",
    "@nestjs/websockets": "^11.0.7",
    "@prisma/client": "^6.3.1",
    "@tien-len/shared": "*",
    "@tien-len/socket": "*",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "ioredis": "^5.4.2",
    "passport": "^0.7.0",
    "passport-facebook": "^3.0.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "prisma": "^6.3.1",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1",
    "typescript": "^5.7.3",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "@nestjs/schematics": "^11.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.1",
    "@types/passport-facebook": "^3.0.3",
    "@types/passport-google-oauth20": "^2.0.16",
    "@types/passport-jwt": "^4.0.1",
    "@types/qrcode": "^1.5.5",
    "@types/uuid": "^10.0.0",
    "ts-node": "^10.9.2"
  }
}
