NODE_ENV=development
PORT=4000

# Public URL users open in the browser (no trailing slash)
# Local:  http://localhost:3000
# Docker: http://YOUR_SERVER_IP  or  https://play.yourdomain.com
# Free cloud: https://YOUR_APP.vercel.app
PUBLIC_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Lite mode: name-only play (no login / profile / scores)
LITE_MODE=true
NEXT_PUBLIC_LITE_MODE=true

# Database (Docker Compose uses these for postgres service)
# Free cloud: paste Neon connection string (?sslmode=require)
POSTGRES_USER=tienlen
POSTGRES_PASSWORD=tienlen
POSTGRES_DB=tienlen
DATABASE_URL=postgresql://tienlen:tienlen@localhost:5432/tienlen?schema=public
# Free cloud: paste Upstash Redis URL (rediss://…)
REDIS_URL=redis://localhost:6379

JWT_SECRET=change-this-to-a-long-random-secret-in-production
REFRESH_TOKEN_DAYS=30
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=http://localhost:4000/api/auth/facebook/callback

# Baked into frontend at build time (Docker uses PUBLIC_URL automatically)
# Free cloud (Vercel): point at Render backend
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_WS_URL=http://localhost:4000
# Tunnel / same-origin proxy only (leave unset on Vercel)
# NEXT_PUBLIC_RELATIVE_URLS=true
