# Optional HTTPS server block — copy snippets into nginx.conf after obtaining certs.
#
# 1. Point your domain A record to the server IP
# 2. Install certbot on the host (not in the container):
#      sudo apt install certbot
#      sudo certbot certonly --standalone -d yourdomain.com
# 3. Copy certs into nginx/ssl/:
#      mkdir -p nginx/ssl
#      sudo cp /etc/letsencrypt/live/yourdomain.com/fullchain.pem nginx/ssl/
#      sudo cp /etc/letsencrypt/live/yourdomain.com/privkey.pem nginx/ssl/
# 4. Add this server block below the port-80 server in nginx.conf

